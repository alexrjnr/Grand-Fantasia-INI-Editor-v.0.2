<UserControl x:Class="GrandFantasiaINIEditor.Modules.Monster.MonsterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:GrandFantasiaINIEditor.Core">

    <Grid Background="#0F0F12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#1A1C22" Padding="12" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="42"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Monster Database"
                           FontSize="22"
                           Margin="0,0,0,10"
                           FontWeight="SemiBold">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="#4FD1FF" Offset="0.0"/>
                            <GradientStop Color="#3A8DFF" Offset="0.6"/>
                            <GradientStop Color="#2B58CC" Offset="1.0"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>

                <TextBox x:Name="SearchBox"
                         Grid.Row="1"
                         Height="32"
                         Margin="0,0,0,10"
                         Background="#23262E"
                         Foreground="White"
                         BorderBrush="#333"
                         Padding="8,6"
                         TextChanged="SearchBox_TextChanged"/>

                <ListBox x:Name="MonsterList"
                         Grid.Row="2"
                         Background="#14161B"
                         BorderBrush="#2B2E36"
                         Foreground="White"
                         SelectionChanged="MonsterList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="30" Height="30" Background="#23262E" BorderBrush="#333" BorderThickness="1" CornerRadius="4" VerticalAlignment="Center">
                                    <Image Source="{Binding Icon}" Stretch="Uniform"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding CompactDisplayName}" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Id}" Foreground="#9AA0AA" FontSize="11"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock x:Name="StatusText" Grid.Row="3" Foreground="#9CD67A" Margin="2,10,0,8"/>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="{loc:Loc Monster.Buttons.Reload}"
                            Height="30"
                            Margin="0,0,4,0"
                            Background="#3A8DFF"
                            Foreground="White"
                            BorderBrush="#3A8DFF"
                            Click="Reload_Click"/>

                    <Button Grid.Column="1"
                            Content="{loc:Loc Monster.Buttons.Clone}"
                            Height="30"
                            Margin="4,0,4,0"
                            Background="#3A8DFF"
                            Foreground="White"
                            BorderBrush="#3A8DFF"
                            Click="Clone_Click"/>

                    <Button Grid.Column="2"
                            Content="{loc:Loc Monster.Buttons.Save}"
                            Height="30"
                            Margin="4,0,0,0"
                            Background="#2E8B57"
                            Foreground="White"
                            BorderBrush="#2E8B57"
                            Click="Save_Click"/>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <TabControl Background="#121318" BorderBrush="#2B2E36" Foreground="White">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border Name="Border" BorderBrush="#2B2E36" BorderThickness="1,1,1,0" CornerRadius="4,4,0,0" Margin="2,0">
                                        <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="12,2"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#1A1C22"/>
                                            <Setter Property="Foreground" Value="Red"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="False">
                                            <Setter TargetName="Border" Property="Background" Value="#23262E"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="AliceBlue"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Margin" Value="0,6,14,6"/>
                        <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
                    </Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Margin" Value="0,6,0,6"/>
                        <Setter Property="Height" Value="28"/>
                        <Setter Property="Background" Value="#23262E"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderBrush" Value="#333"/>
                        <Setter Property="Padding" Value="8,4"/>
                    </Style>
                    <Style TargetType="ComboBox">
                        <Setter Property="Margin" Value="0,6,0,6"/>
                        <Setter Property="Height" Value="28"/>
                        <Setter Property="Background" Value="#23262E"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderBrush" Value="#333"/>
                        <Setter Property="IsEditable" Value="True"/>
                        <Setter Property="IsReadOnly" Value="True"/>
                        <Setter Property="ItemContainerStyle">
                            <Setter.Value>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="Background" Value="White"/>
                                </Style>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <TabItem Header="Geral">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Width="72" Height="72" CornerRadius="10" BorderBrush="Gold" BorderThickness="2" Background="#23262E" HorizontalAlignment="Left" VerticalAlignment="Top">
                                <Image x:Name="MonsterIcon" Width="56" Height="56" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Text="ID" Grid.Row="0" Grid.Column="1"/>
                            <TextBox x:Name="IdBox" Grid.Row="0" Grid.Column="1" Margin="34,6,0,6" IsReadOnly="True"/>

                            <TextBlock Text="Nome (S_Monster)" Grid.Row="1" Grid.Column="1"/>
                            <TextBox x:Name="NameBox" Grid.Row="1" Grid.Column="1" Margin="120,6,0,6"/>

                            <TextBlock Text="Nome (T_Monster)" Grid.Row="2" Grid.Column="0"/>
                            <TextBox x:Name="TranslatedNameBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" Height="72" VerticalScrollBarVisibility="Auto"/>

                            <TextBlock Text="ModelIds" Grid.Row="3" Grid.Column="0"/>
                            <TextBox x:Name="ModelIdsBox" Grid.Row="3" Grid.Column="1"/>

                            <TextBlock Text="Level" Grid.Row="3" Grid.Column="2"/>
                            <TextBox x:Name="LevelBox" Grid.Row="3" Grid.Column="3"/>

                            <TextBlock Text="Rank" Grid.Row="4" Grid.Column="0"/>
                            <ComboBox x:Name="RankCombo" Grid.Row="4" Grid.Column="1" DisplayMemberPath="Label" SelectedValuePath="Value"/>

                            <TextBlock Text="MonsterAlignment" Grid.Row="4" Grid.Column="2"/>
                            <ComboBox x:Name="MonsterAlignmentCombo" Grid.Row="4" Grid.Column="3" DisplayMemberPath="Label" SelectedValuePath="Value"/>

                            <TextBlock Text="Type" Grid.Row="5" Grid.Column="0"/>
                            <ComboBox x:Name="TypeCombo" Grid.Row="5" Grid.Column="1" DisplayMemberPath="Label" SelectedValuePath="Value"/>

                            <TextBlock Text="SpecialFlag" Grid.Row="5" Grid.Column="2"/>
                            <TextBox x:Name="SpecialFlagBox" Grid.Row="5" Grid.Column="3"/>

                            <TextBlock Text="ZoneIcon" Grid.Row="6" Grid.Column="0"/>
                            <TextBox x:Name="ZoneIconBox" Grid.Row="6" Grid.Column="1"/>

                            <TextBlock Text="ESummonType" Grid.Row="6" Grid.Column="2"/>
                            <ComboBox x:Name="SummonTypeCombo" Grid.Row="6" Grid.Column="3" DisplayMemberPath="Label" SelectedValuePath="Value"/>

                            <TextBlock Text="MaxHp" Grid.Row="7" Grid.Column="0"/>
                            <TextBox x:Name="MaxHpQuickBox" Grid.Row="7" Grid.Column="1" IsReadOnly="True"/>

                            <TextBlock Text="MaxMp" Grid.Row="7" Grid.Column="2"/>
                            <TextBox x:Name="MaxMpQuickBox" Grid.Row="7" Grid.Column="3" IsReadOnly="True"/>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Status">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="MaxHp" Grid.Row="0" Grid.Column="0"/><TextBox x:Name="MaxHpBox" Grid.Row="0" Grid.Column="1"/>
                            <TextBlock Text="MaxMp" Grid.Row="0" Grid.Column="2"/><TextBox x:Name="MaxMpBox" Grid.Row="0" Grid.Column="3"/>

                            <TextBlock Text="FearType" Grid.Row="1" Grid.Column="0"/><ComboBox x:Name="FearTypeCombo" Grid.Row="1" Grid.Column="1" DisplayMemberPath="Label" SelectedValuePath="Value"/>
                            <TextBlock Text="PartHP" Grid.Row="1" Grid.Column="2"/><TextBox x:Name="PartHpBox" Grid.Row="1" Grid.Column="3"/>

                            <TextBlock Text="PartBreakingAction" Grid.Row="2" Grid.Column="0"/><TextBox x:Name="PartBreakingActionBox" Grid.Row="2" Grid.Column="1"/>
                            <TextBlock Text="AvgPhysicoDamage" Grid.Row="2" Grid.Column="2"/><TextBox x:Name="AvgPhysicoDamageBox" Grid.Row="2" Grid.Column="3"/>

                            <TextBlock Text="RandPhysicoDamage" Grid.Row="3" Grid.Column="0"/><TextBox x:Name="RandPhysicoDamageBox" Grid.Row="3" Grid.Column="1"/>
                            <TextBlock Text="AttackRange" Grid.Row="3" Grid.Column="2"/><TextBox x:Name="AttackRangeBox" Grid.Row="3" Grid.Column="3"/>

                            <TextBlock Text="AttackSpeed" Grid.Row="4" Grid.Column="0"/><TextBox x:Name="AttackSpeedBox" Grid.Row="4" Grid.Column="1"/>
                            <TextBlock Text="Attack" Grid.Row="4" Grid.Column="2"/><TextBox x:Name="AttackBox" Grid.Row="4" Grid.Column="3"/>

                            <TextBlock Text="PhysicoDefence" Grid.Row="5" Grid.Column="0"/><TextBox x:Name="PhysicoDefenceBox" Grid.Row="5" Grid.Column="1"/>
                            <TextBlock Text="MagicDamage" Grid.Row="5" Grid.Column="2"/><TextBox x:Name="MagicDamageBox" Grid.Row="5" Grid.Column="3"/>

                            <TextBlock Text="MagicDefence" Grid.Row="6" Grid.Column="0"/><TextBox x:Name="MagicDefenceBox" Grid.Row="6" Grid.Column="1"/>
                            <TextBlock Text="HitRate" Grid.Row="6" Grid.Column="2"/><TextBox x:Name="HitRateBox" Grid.Row="6" Grid.Column="3"/>

                            <TextBlock Text="DodgeRate" Grid.Row="7" Grid.Column="0"/><TextBox x:Name="DodgeRateBox" Grid.Row="7" Grid.Column="1"/>
                            <TextBlock Text="PhysicoCriticalRate" Grid.Row="7" Grid.Column="2"/><TextBox x:Name="PhysicoCriticalRateBox" Grid.Row="7" Grid.Column="3"/>

                            <TextBlock Text="PhysicoCriticalDamage" Grid.Row="8" Grid.Column="0"/><TextBox x:Name="PhysicoCriticalDamageBox" Grid.Row="8" Grid.Column="1"/>
                            <TextBlock Text="MagicCriticalRate" Grid.Row="8" Grid.Column="2"/><TextBox x:Name="MagicCriticalRateBox" Grid.Row="8" Grid.Column="3"/>

                            <TextBlock Text="MagicCriticalDamage" Grid.Row="9" Grid.Column="0"/><TextBox x:Name="MagicCriticalDamageBox" Grid.Row="9" Grid.Column="1"/>
                            <TextBlock Text="PhysicalPenetration" Grid.Row="9" Grid.Column="2"/><TextBox x:Name="PhysicalPenetrationBox" Grid.Row="9" Grid.Column="3"/>

                            <TextBlock Text="MagicalPenetration" Grid.Row="10" Grid.Column="0"/><TextBox x:Name="MagicalPenetrationBox" Grid.Row="10" Grid.Column="1"/>
                            <TextBlock Text="PhysicalPenetrationDefence" Grid.Row="10" Grid.Column="2"/><TextBox x:Name="PhysicalPenetrationDefenceBox" Grid.Row="10" Grid.Column="3"/>

                            <TextBlock Text="MagicalPenetrationDefence" Grid.Row="11" Grid.Column="0"/><TextBox x:Name="MagicalPenetrationDefenceBox" Grid.Row="11" Grid.Column="1"/>
                            <TextBlock Text="Attribute" Grid.Row="11" Grid.Column="2"/><ComboBox x:Name="AttributeCombo" Grid.Row="11" Grid.Column="3" DisplayMemberPath="Label" SelectedValuePath="Value"/>

                            <TextBlock Text="AttributeDamage" Grid.Row="12" Grid.Column="0"/><TextBox x:Name="AttributeDamageBox" Grid.Row="12" Grid.Column="1"/>
                            <TextBlock Text="AttributeRate" Grid.Row="12" Grid.Column="2"/><TextBox x:Name="AttributeRateBox" Grid.Row="12" Grid.Column="3"/>

                            <TextBlock Text="AttributeResist" Grid.Row="13" Grid.Column="0"/><TextBox x:Name="AttributeResistBox" Grid.Row="13" Grid.Column="1"/>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Spells/Summons">
                    <Grid Margin="14">
                        <ListView x:Name="SpellsColumnsList" Background="#14161B" BorderBrush="#2B2E36" Foreground="White">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="#" Width="54" DisplayMemberBinding="{Binding Index}"/>
                                    <GridViewColumn Header="Coluna" Width="240" DisplayMemberBinding="{Binding Name}"/>
                                    <GridViewColumn Header="Valor" Width="700">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Background="#23262E" Foreground="White" BorderBrush="#333" Padding="6,3" Height="28"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </TabItem>

                <TabItem Header="Outros">
                    <Grid Margin="14">
                        <ListView x:Name="OtherColumnsList" Background="#14161B" BorderBrush="#2B2E36" Foreground="White">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="#" Width="54" DisplayMemberBinding="{Binding Index}"/>
                                    <GridViewColumn Header="Coluna" Width="240" DisplayMemberBinding="{Binding Name}"/>
                                    <GridViewColumn Header="Valor" Width="700">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Background="#23262E" Foreground="White" BorderBrush="#333" Padding="6,3" Height="28"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </TabItem>

                <TabItem Header="Limites">
                    <Grid Margin="14">
                        <ListView x:Name="LimitsColumnsList" Background="#14161B" BorderBrush="#2B2E36" Foreground="White">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="#" Width="54" DisplayMemberBinding="{Binding Index}"/>
                                    <GridViewColumn Header="Coluna" Width="240" DisplayMemberBinding="{Binding Name}"/>
                                    <GridViewColumn Header="Valor" Width="700">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Background="#23262E" Foreground="White" BorderBrush="#333" Padding="6,3" Height="28"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </TabItem>

                <TabItem Header="Todas Colunas">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Editor completo do S_Monster.ini (100% das colunas)." Margin="0,0,0,8"/>

                        <ListView x:Name="AllColumnsList"
                                  Grid.Row="1"
                                  Background="#14161B"
                                  BorderBrush="#2B2E36"
                                  Foreground="White">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="#" Width="54" DisplayMemberBinding="{Binding Index}"/>
                                    <GridViewColumn Header="Coluna" Width="240" DisplayMemberBinding="{Binding Name}"/>
                                    <GridViewColumn Header="Valor" Width="700">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                         Background="#23262E"
                                                         Foreground="White"
                                                         BorderBrush="#333"
                                                         Padding="6,3"
                                                         Height="28"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</UserControl>
