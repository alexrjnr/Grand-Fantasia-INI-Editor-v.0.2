<UserControl x:Class="GrandFantasiaINIEditor.Modules.Mission.MissionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:loc="clr-namespace:GrandFantasiaINIEditor.Core">

    <Grid Background="#0F0F12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LISTA -->
        <Border Background="#1A1C22" Padding="12" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="42"/>
                </Grid.RowDefinitions>

                <TextBlock Text="{loc:Loc Mission.Title}"
                           FontSize="22"
                           Margin="0,0,0,10"
                           FontWeight="SemiBold">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="#4FD1FF" Offset="0.0" />
                            <GradientStop Color="#3A8DFF" Offset="0.6" />
                            <GradientStop Color="#2B58CC" Offset="1.0" />
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>

                <TextBox x:Name="SearchBox"
                         Grid.Row="1"
                         Height="32"
                         Margin="0,0,0,10"
                         Background="#23262E"
                         Foreground="White"
                         BorderBrush="#333"
                         Padding="8,6"
                         TextChanged="SearchBox_TextChanged"/>

                <ListBox x:Name="MissionList"
                         Grid.Row="2"
                         Background="#14161B"
                         Foreground="White"
                         BorderBrush="#2B2E36"
                         SelectionChanged="MissionList_SelectionChanged"/>

                <Grid Grid.Row="3" Margin="0,10,0,-10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="{loc:Loc Mission.Buttons.Resync}"
                            FontSize="9"
                            Height="30"
                            Margin="0,0,8,0"
                            Background="#A020F0"
                            Foreground="White"
                            BorderBrush="#A020F0"
                            Click="Reload_Click"/>

                    <Button Grid.Column="1"
                            Content="{loc:Loc Mission.Buttons.Save}"
                            FontSize="9"
                            Height="30"
                            Margin="4,0,4,0"
                            Background="#2E8B57"
                            Foreground="White"
                            BorderBrush="#2E8B57"
                            Click="Save_Click"/>

                    <Button Grid.Column="2"
                            Content="{loc:Loc Mission.Buttons.Clone}"
                            FontSize="9"
                            Height="30"
                            Margin="8,0,0,0"
                            Background="#3A8DFF"
                            Foreground="White"
                            BorderBrush="#3A8DFF"
                            Click="Clone_Click"/>
                </Grid>
            </Grid>
        </Border>

        <!-- EDITOR -->
        <Grid Grid.Column="1">
            <TabControl Background="#121318" BorderBrush="#2B2E36" Foreground="White">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border Name="Border" BorderBrush="#2B2E36" BorderThickness="1,1,1,0" CornerRadius="4,4,0,0" Margin="2,0">
                                        <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="12,2"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#1A1C22"/>
                                            <Setter Property="Foreground" Value="Red"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="False">
                                            <Setter TargetName="Border" Property="Background" Value="#23262E"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- GERAL -->
                <TabItem Header="{loc:Loc Mission.Tabs.General}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Height="570">
                        <Grid Margin="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="123"/>
                                <ColumnDefinition Width="17"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="{loc:Loc Mission.Labels.MissionId}"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Center"
                                       Grid.ColumnSpan="3"
                                       HorizontalAlignment="Left"
                                       Width="140"
                                       Margin="22,0,0,0"/>
                            <TextBox x:Name="MissionIdBox"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     IsReadOnly="True"
                                     Margin="89,7,171,8"
                                     Grid.ColumnSpan="3"/>

                            <TextBlock Text="{loc:Loc Mission.Labels.MissionName}"
                                       Grid.Column="2"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Center"
                                       Grid.ColumnSpan="2"
                                       Margin="101,0,119,0"/>
                            <TextBox x:Name="NameBox"
                                     Grid.Column="2"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Margin="189,7,10,54"
                                     Grid.ColumnSpan="3" Grid.RowSpan="2"/>

                            <TextBlock Text="{loc:Loc Mission.Labels.Location}"
                                       Grid.Row="1"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top"
                                       HorizontalAlignment="Left"
                                       Width="70"
                                       Margin="17,8,0,0"/>

                            <Grid Grid.Row="1" Grid.ColumnSpan="3" Margin="89,7,171,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBox x:Name="ClassificationBox"
                                         Grid.Row="0"
                                         Background="#23262E"
                                         Foreground="White"
                                         BorderBrush="#333" Margin="0,0,0,-12" Grid.RowSpan="2"/>


                            </Grid>

                            <TextBlock Text="{loc:Loc Mission.Labels.DeclineLevel}"
                                       Grid.Row="1"
                                       Grid.Column="2"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top"
                                       Grid.ColumnSpan="2"
                                       Margin="114,18,106,0"/>
                            <TextBox x:Name="DeclineLevelBox"
                                     Grid.Row="1"
                                     Grid.Column="2"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Margin="192,17,58,19"
                                     Grid.ColumnSpan="2"/>

                            <TextBlock Text="{loc:Loc Mission.Labels.MissionType}"
                                       Grid.Row="1"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top"
                                       Grid.ColumnSpan="3"
                                       Margin="12,49,208,0" Grid.RowSpan="2"/>
                            <ComboBox x:Name="MissionTypeCombo"
                                      Grid.Row="1"
                                      Background="#23262E"
                                      Foreground="Black"
                                      BorderBrush="#333"
                                      Margin="89,46,171,21"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      Grid.ColumnSpan="3" Grid.RowSpan="2">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="Background" Value="White"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>

                            <TextBlock Text="{loc:Loc Mission.Labels.TriggerLevel}"
                                       Grid.Row="2"
                                       Grid.Column="2"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top"
                                       Grid.ColumnSpan="2"
                                       Margin="114,6,106,0"/>
                            <TextBox x:Name="TriggerLevelBox"
                                     Grid.Row="2"
                                     Grid.Column="2"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Margin="192,8,58,7"
                                     Grid.ColumnSpan="2"/>

                            <TextBlock Text="{loc:Loc Mission.Labels.TriggerNodeId}"
                                       Grid.Row="3"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Center"
                                       Grid.ColumnSpan="2"/>
                            <TextBox x:Name="TriggerNodeIdBox"
                                     Grid.Row="3"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Margin="89,7,171,8"
                                     Grid.ColumnSpan="3"/>

                            <TextBlock Text="{loc:Loc Mission.Labels.Note}"
                                       Grid.Row="4"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Center"
                                       Grid.ColumnSpan="3"
                                       Margin="49,0,171,0"/>
                            <TextBox x:Name="NoteBox"
                                     Grid.Row="4"
                                     Grid.ColumnSpan="4"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Margin="92,25,58,10"
                                     Height="90"
                                     Grid.RowSpan="2"/>

                            <TextBlock Text="{loc:Loc Mission.Labels.MissionFlags}"
                                       Grid.Row="1"
                                       Grid.Column="3"
                                       Grid.ColumnSpan="2"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top"
                                       Margin="105,18,-95,0"/>

                            <TextBlock x:Name="missionflags_value"
                                       Grid.Row="1"
                                       Grid.Column="4"
                                       Foreground="#C8C8C8"
                                       FontFamily="Consolas"
                                       VerticalAlignment="Top"
                                       HorizontalAlignment="Left"
                                       Text="0 | 0x0"
                                       Margin="154,20,0,0"/>

                            <Border Grid.Row="2"
                                    Grid.Column="3"
                                    Background="#17191F"
                                    BorderBrush="#333"
                                    BorderThickness="1"
                                    Padding="10"
                                    CornerRadius="6"
                                    Margin="105,5,10,0"
                                    Grid.RowSpan="5"
                                    Grid.ColumnSpan="2">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxWidth="420" MaxHeight="420">
                                    <UniformGrid x:Name="missionflags_grid" Columns="2"/>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <!-- ACCEPT / FINISH -->
                <TabItem Header="{loc:Loc Mission.Tabs.AcceptFinish}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Height="576">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="{loc:Loc Mission.Labels.AcceptNpc}"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"/>

                            <Border Grid.Row="1"
                                    Margin="0,8,0,12"
                                    Background="#17191F"
                                    BorderBrush="#333"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox x:Name="AcceptNpcBox"
                                             Grid.Column="0"
                                             Background="#1B1E24"
                                             Foreground="White"
                                             BorderBrush="#333"
                                             Padding="6,4"
                                             TextChanged="AcceptNpcBox_TextChanged"/>

                                    <TextBlock x:Name="AcceptNpcLegendBox"
                                               Grid.Column="2"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"
                                               Foreground="#C8C8C8"/>
                                </Grid>
                            </Border>

                            <TextBlock Grid.Row="2"
                                       Text="{loc:Loc Mission.Labels.AcceptItem}"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"/>

                            <Border Grid.Row="3"
                                    Margin="0,8,0,12"
                                    Background="#17191F"
                                    BorderBrush="#333"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox x:Name="AcceptItemBox"
                                             Grid.Column="0"
                                             Background="#1B1E24"
                                             Foreground="White"
                                             BorderBrush="#333"
                                             Padding="6,4"
                                             TextChanged="AcceptItemBox_TextChanged"/>

                                    <TextBlock x:Name="AcceptItemLegendBox"
                                               Grid.Column="2"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"
                                               Foreground="#C8C8C8"/>
                                </Grid>
                            </Border>

                            <TextBlock Grid.Row="4"
                                       Text="{loc:Loc Mission.Labels.AcceptDialog}"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"/>
                            <TextBox x:Name="AcceptDialogIdBox"
                                     Grid.Row="5"
                                     Height="32"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Padding="8,6"
                                     Margin="0,8,0,12"/>

                            <TextBlock Grid.Row="6"
                                       Text="{loc:Loc Mission.Labels.FinishNpc}"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"/>

                            <Border Grid.Row="7"
                                    Margin="0,8,0,12"
                                    Background="#17191F"
                                    BorderBrush="#333"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox x:Name="FinishNpcBox"
                                             Grid.Column="0"
                                             Background="#1B1E24"
                                             Foreground="White"
                                             BorderBrush="#333"
                                             Padding="6,4"
                                             TextChanged="FinishNpcBox_TextChanged"/>

                                    <TextBlock x:Name="FinishNpcLegendBox"
                                               Grid.Column="2"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"
                                               Foreground="#C8C8C8"/>
                                </Grid>
                            </Border>

                            <TextBlock Grid.Row="8"
                                       Text="{loc:Loc Mission.Labels.FinishItem}"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"/>

                            <Border Grid.Row="9"
                                    Margin="0,8,0,12"
                                    Background="#17191F"
                                    BorderBrush="#333"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox x:Name="FinishItemBox"
                                             Grid.Column="0"
                                             Background="#1B1E24"
                                             Foreground="White"
                                             BorderBrush="#333"
                                             Padding="6,4"
                                             TextChanged="FinishItemBox_TextChanged"/>

                                    <TextBlock x:Name="FinishItemLegendBox"
                                               Grid.Column="2"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"
                                               Foreground="#C8C8C8"/>
                                </Grid>
                            </Border>

                            <TextBlock Grid.Row="10"
                                       Text="{loc:Loc Mission.Labels.FinishDialog}"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"/>
                            <TextBox x:Name="FinishDialogIdBox"
                                     Grid.Row="11"
                                     Height="32"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Padding="8,6"
                                     Margin="0,8,0,12"/>

                            <TextBlock Grid.Row="11"
                                       Text="{loc:Loc Mission.Labels.CompleteDialog}"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       Margin="0,46,0,-46"/>

                            <TextBox x:Name="CompleteDialogIdBox"
                                     Grid.Row="11"
                                     Height="32"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Padding="8,6"
                                     Margin="0,67,0,-47"/>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <!-- CONDIÇÕES -->
                <TabItem Header="{loc:Loc Mission.Labels.Conditions}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="{loc:Loc Mission.Labels.AcceptConditions}"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"/>

                            <Border Grid.Row="1"
                                    Margin="0,8,0,12"
                                    Background="#17191F"
                                    BorderBrush="#333"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8">
                                <ListBox x:Name="AcceptConditionsList"
                                         Background="#17191F"
                                         Foreground="White"
                                         BorderThickness="0">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,0,4"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Focusable" Value="False"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>

                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Background="#23262E" Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="260"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text=":"
                                                           Foreground="White"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           FontFamily="Consolas"
                                                           FontSize="14"/>

                                                <TextBox Grid.Column="1"
                                                         Text="{Binding EditableText, UpdateSourceTrigger=PropertyChanged}"
                                                         Tag="{Binding}"
                                                         TextChanged="AcceptConditionEditor_TextChanged"
                                                         Background="#1B1E24"
                                                         Foreground="White"
                                                         BorderBrush="#333"
                                                         Padding="6,4"
                                                         FontFamily="Consolas"
                                                         FontSize="13"/>

                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding LegendText}"
                                                           Foreground="#C8C8C8"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,6,0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>

                            <TextBlock Grid.Row="2"
                                       Margin="0,8,0,0"
                                       Text="{loc:Loc Mission.Labels.FinishConditions}"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"/>

                            <Border Grid.Row="3"
                                    Margin="0,8,0,12"
                                    Background="#17191F"
                                    BorderBrush="#333"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8">
                                <ListBox x:Name="FinishConditionsList"
                                         Background="#17191F"
                                         Foreground="White"
                                         BorderThickness="0">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,0,4"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Focusable" Value="False"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>

                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Background="#23262E" Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="260"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text=":"
                                                           Foreground="White"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           FontFamily="Consolas"
                                                           FontSize="14"/>

                                                <TextBox Grid.Column="1"
                                                         Text="{Binding EditableText, UpdateSourceTrigger=PropertyChanged}"
                                                         Tag="{Binding}"
                                                         TextChanged="FinishConditionEditor_TextChanged"
                                                         Background="#1B1E24"
                                                         Foreground="White"
                                                         BorderBrush="#333"
                                                         Padding="6,4"
                                                         FontFamily="Consolas"
                                                         FontSize="13"/>

                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding LegendText}"
                                                           Foreground="#C8C8C8"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,6,0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>

                            <TextBlock Grid.Row="4"
                                       Margin="0,8,0,0"
                                       Text="{loc:Loc Mission.Labels.AcceptRawCmds}"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"/>

                            <Border Grid.Row="5"
                                    Margin="0,8,0,12"
                                    Background="#17191F"
                                    BorderBrush="#333"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8">
                                <TextBox x:Name="AcceptRawCmdsBox"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         MinHeight="100"
                                         Background="#1B1E24"
                                         Foreground="White"
                                         BorderBrush="#333"
                                         Padding="6,4"
                                         FontFamily="Consolas"
                                         FontSize="13"/>
                            </Border>

                            <TextBlock Grid.Row="6"
                                       Margin="0,8,0,0"
                                       Text="{loc:Loc Mission.Labels.RecycleItems}"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"/>

                            <Border Grid.Row="7"
                                    Margin="0,8,0,12"
                                    Background="#17191F"
                                    BorderBrush="#333"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8">
                                <TextBox x:Name="RecycleItemsBox"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         MinHeight="100"
                                         Background="#1B1E24"
                                         Foreground="White"
                                         BorderBrush="#333"
                                         Padding="6,4"
                                         FontFamily="Consolas"
                                         FontSize="13"/>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <!-- REWARDS -->
                <TabItem Header="{loc:Loc Mission.Labels.Rewards}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="{loc:Loc Mission.Labels.Rewards}"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"/>

                            <Border Grid.Row="1"
                                    Margin="0,8,0,12"
                                    Background="#17191F"
                                    BorderBrush="#333"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8">
                                <ListBox x:Name="RewardsList"
                                         Background="#17191F"
                                         Foreground="White"
                                         BorderThickness="0">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,0,4"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Focusable" Value="False"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>

                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Background="#23262E" Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="320"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text=":"
                                                           Foreground="White"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           FontFamily="Consolas"
                                                           FontSize="14"/>

                                                <TextBox Grid.Column="1"
                                                         Text="{Binding EditableText, UpdateSourceTrigger=PropertyChanged}"
                                                         Tag="{Binding}"
                                                         TextChanged="RewardEditor_TextChanged"
                                                         Background="#1B1E24"
                                                         Foreground="White"
                                                         BorderBrush="#333"
                                                         Padding="6,4"
                                                         FontFamily="Consolas"
                                                         FontSize="13"/>

                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding LegendText}"
                                                           Foreground="#C8C8C8"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,6,0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Grid>
    </Grid>
</UserControl>