<UserControl x:Class="GrandFantasiaINIEditor.Modules.Store.StoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:GrandFantasiaINIEditor.Core"
             mc:Ignorable="d">

    <Grid Background="#0F0F12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LISTA -->
        <Border Grid.Column="0"
                Background="#1A1C22"
                Padding="12"
                Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="42"/>
                </Grid.RowDefinitions>

                <TextBlock Text="{loc:Loc Store.Title}"
           FontSize="22"
           Margin="0,0,0,10"
           FontWeight="SemiBold">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="#4FD1FF" Offset="0.0" />
                            <GradientStop Color="#3A8DFF" Offset="0.6" />
                            <GradientStop Color="#2B58CC" Offset="1.0" />
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>
                
                
                <TextBox x:Name="SearchBox"
                         Grid.Row="1"
                         Height="34"
                         Margin="0,0,0,10"
                         Background="#23262E"
                         Foreground="White"
                         BorderBrush="#333"
                         VerticalContentAlignment="Center"
                         Padding="10,0"
                         TextChanged="SearchBox_TextChanged"/>

                <ListBox x:Name="StoreList"
                         Grid.Row="2"
                         Background="#14161B"
                         Foreground="White"
                         BorderBrush="#333"
                         SelectionChanged="StoreList_SelectionChanged"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="6,4" Margin="1" CornerRadius="4" Background="Transparent">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="32" Height="32"
                                            Background="#15171C"
                                            BorderBrush="Gold" BorderThickness="1"
                                            CornerRadius="3">
                                        <Image Source="{Binding Icon}" Stretch="Uniform"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding Id}"
                                                   FontSize="11" Foreground="#888"/>
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="12" FontWeight="SemiBold" Foreground="White"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Grid Grid.Row="3" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="{loc:Loc Common.Reload}"
                            FontSize="9"
                            Height="30"
                            Margin="0,0,8,0"
                            Background="#A020F0"
                            Foreground="White"
                            BorderBrush="#A020F0"
                            Click="Reload_Click"/>

                    <Button Grid.Column="1"
                            Content="{loc:Loc Common.Save}"
                            FontSize="9"
                            Height="30"
                            Margin="4,0,4,0"
                            Background="#2E8B57"
                            Foreground="White"
                            BorderBrush="#2E8B57"
                            Click="Save_Click"/>

                    <Button Grid.Column="2"
                            Content="{loc:Loc Common.Clone}"
                            FontSize="9"
                            Height="30"
                            Margin="8,0,0,0"
                            Background="#3A8DFF"
                            Foreground="White"
                            BorderBrush="#3A8DFF"
                            Click="Clone_Click"/>
                </Grid>
            </Grid>
        </Border>

        <!-- DIREITA -->
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- CABEÇALHO -->
                <Border Background="#1A1C22"
                        CornerRadius="8"
                        Padding="14"
                        Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Linha 1 -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{loc:Loc Store.Headers.StoreId}"
                                       Foreground="AliceBlue"
                                       VerticalAlignment="Center"/>

                            <TextBox x:Name="StoreIdBox"
                                     Grid.Column="1"
                                     Height="30"
                                     Margin="8,0,20,0"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"/>

                            <TextBlock Grid.Column="2"
                                       Text="{loc:Loc Store.Headers.Discount}"
                                       Foreground="AliceBlue"
                                       VerticalAlignment="Center"/>

                            <ComboBox x:Name="DiscountCombo"
                                      Grid.Column="3"
                                      Height="30"
                                      Margin="8,0,20,0"
                                      Background="#23262E"
                                      Foreground="Black"
                                      BorderBrush="#333"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"/>

                            <TextBlock Grid.Column="4"
                                       x:Name="StoreSummaryText"
                                       Foreground="#8ED0FF"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       FontWeight="SemiBold"/>
                        </Grid>

                        <!-- Linha 2 -->
                        <Grid Grid.Row="1" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="PrevPageButton"
                                    Grid.Column="2" 
                                    Content="{loc:Loc Store.Buttons.PrevPage}" HorizontalAlignment="Left"
                                    Width="130"
                                    Height="40"
                                    Click="PrevPage_Click"/>

                            <Button x:Name="NextPageButton"
                                    Grid.Column="2" HorizontalAlignment="Center"
                                    Content="{loc:Loc Store.Buttons.NextPage}"
                                    Width="130"
                                    Height="40"
                                    Click="NextPage_Click"/>

                            <TextBlock x:Name="PageInfoText"
                                       Grid.Column="2"
                                       Foreground="White"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- SLOTS -->
                <Border Background="#1A1C22"
                        CornerRadius="8"
                        Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ESQUERDA -->
                        <ItemsControl x:Name="LeftSlotsList" Grid.Column="0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#23262E"
                                            BorderBrush="#333"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="4"
                                            Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="54"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Ícone -->
                                            <Border Width="48"
                                                    Height="48"
                                                    Background="#15171C"
                                                    BorderBrush="Gold"
                                                    BorderThickness="2"
                                                    CornerRadius="4"
                                                    VerticalAlignment="Top">
                                                <Image Source="{Binding Icon}" 
                                                       Stretch="Uniform"/>
                                            </Border>

                                            <!-- Conteúdo -->
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock Text="{Binding SlotLabel}"
                                                           Foreground="#8ED0FF"
                                                           FontWeight="SemiBold"
                                                           FontSize="11"
                                                           Margin="0,0,0,2"/>

                                                <Grid Margin="0,0,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="50"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="{loc:Loc Store.Headers.ItemId}"
                                                               FontSize="11"
                                                               Foreground="AliceBlue"
                                                               VerticalAlignment="Center"/>

                                                    <TextBox Grid.Column="1"
                                                             Height="22"
                                                             FontSize="11"
                                                             Background="#1B1D23"
                                                             Foreground="White"
                                                             BorderBrush="#3A3A3A"
                                                             Text="{Binding ItemId, UpdateSourceTrigger=PropertyChanged}"
                                                             TextChanged="SlotItemId_TextChanged"
                                                             Tag="{Binding}"/>
                                                </Grid>

                                                <Grid Margin="0,0,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="50"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="{loc:Loc Store.Headers.Quantity}"
                                                               FontSize="11"
                                                               Foreground="AliceBlue"
                                                               VerticalAlignment="Center"/>

                                                    <TextBox Grid.Column="1"
                                                             Height="22"
                                                             FontSize="11"
                                                             Background="#1B1D23"
                                                             Foreground="White"
                                                             BorderBrush="#3A3A3A"
                                                             Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                                             Tag="{Binding}"/>
                                                </Grid>

                                                <TextBlock Text="{Binding VisualName}"
                                                           Foreground="White"
                                                           FontWeight="SemiBold"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"/>

                                                <TextBlock Text="{Binding VisualInfo}"
                                                           Foreground="#B8C2D0"
                                                           FontSize="10"
                                                           Margin="0,1,0,0"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- DIREITA -->
                        <ItemsControl x:Name="RightSlotsList" Grid.Column="2">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#23262E"
                                            BorderBrush="#333"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="4"
                                            Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="54"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Ícone -->
                                            <Border Width="48"
                                                    Height="48"
                                                    Background="#15171C"
                                                    BorderBrush="Gold"
                                                    BorderThickness="2"
                                                    CornerRadius="4"
                                                    VerticalAlignment="Top">
                                                <Image Source="{Binding Icon}"
                                                       Stretch="Uniform"/>
                                            </Border>

                                            <!-- Conteúdo -->
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock Text="{Binding SlotLabel}"
                                                           Foreground="#8ED0FF"
                                                           FontWeight="SemiBold"
                                                           FontSize="11"
                                                           Margin="0,0,0,2"/>

                                                <Grid Margin="0,0,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="50"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="{loc:Loc Store.Headers.ItemId}"
                                                               FontSize="11"
                                                               Foreground="AliceBlue"
                                                               VerticalAlignment="Center"/>

                                                    <TextBox Grid.Column="1"
                                                             Height="22"
                                                             FontSize="11"
                                                             Background="#1B1D23"
                                                             Foreground="White"
                                                             BorderBrush="#3A3A3A"
                                                             Text="{Binding ItemId, UpdateSourceTrigger=PropertyChanged}"
                                                             TextChanged="SlotItemId_TextChanged"
                                                             Tag="{Binding}"/>
                                                </Grid>

                                                <Grid Margin="0,0,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="50"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="{loc:Loc Store.Headers.Quantity}"
                                                               FontSize="11"
                                                               Foreground="AliceBlue"
                                                               VerticalAlignment="Center"/>

                                                    <TextBox Grid.Column="1"
                                                             Height="22"
                                                             FontSize="11"
                                                             Background="#1B1D23"
                                                             Foreground="White"
                                                             BorderBrush="#3A3A3A"
                                                             Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                                             Tag="{Binding}"/>
                                                </Grid>

                                                <TextBlock Text="{Binding VisualName}"
                                                           Foreground="White"
                                                           FontWeight="SemiBold"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"/>

                                                <TextBlock Text="{Binding VisualInfo}"
                                                           Foreground="#B8C2D0"
                                                           FontSize="10"
                                                           Margin="0,1,0,0"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>