<UserControl x:Class="GrandFantasiaINIEditor.Modules.DropItem.DropItemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1000">

    <Grid Background="#0F0F12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LISTA ESQUERDA ═══ -->
        <Border Grid.Column="0" Background="#1A1C22" Padding="12" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="42"/>
                </Grid.RowDefinitions>

                <TextBlock Text="DropItem Database"
                             FontSize="22"
  Margin="0,0,0,10"
  FontWeight="SemiBold">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="#4FD1FF" Offset="0.0" />
                            <GradientStop Color="#3A8DFF" Offset="0.6" />
                            <GradientStop Color="#2B58CC" Offset="1.0" />
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>

                <TextBox x:Name="SearchBox"
                         Grid.Row="1"
                         Height="32" Margin="0,0,0,10"
                         Background="#23262E" Foreground="White"
                         BorderBrush="#333" Padding="8,6"
                         TextChanged="SearchBox_TextChanged"/>

                <ListBox x:Name="DropList"
                         Grid.Row="2"
                         Background="#14161B" Foreground="White"
                         BorderBrush="#2B2E36"
                         SelectionChanged="DropList_SelectionChanged"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="6,4" Margin="1" CornerRadius="4" Background="Transparent">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="32" Height="32"
                                            Background="#15171C"
                                            BorderBrush="#444" BorderThickness="1"
                                            CornerRadius="3">
                                        <Image Source="{Binding Icon}" Stretch="Uniform"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,0,0">
                                        <TextBlock Text="{Binding Id}"
                                                   FontSize="11" Foreground="#888"/>
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="12" FontWeight="SemiBold" Foreground="White"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Botões -->
                <Grid Grid.Row="3" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="Recarregar"
                            FontSize="9" Height="30" Margin="0,0,8,0"
                            Background="#A020F0" Foreground="White" BorderBrush="#A020F0"
                            Click="Reload_Click"/>

                    <Button Grid.Column="1" Content="Salvar"
                            FontSize="9" Height="30" Margin="4,0"
                            Background="#2E8B57" Foreground="White" BorderBrush="#2E8B57"
                            Click="Save_Click"/>

                    <Button Grid.Column="2" Content="Clonar"
                            FontSize="9" Height="30" Margin="8,0,0,0"
                            Background="#3A8DFF" Foreground="White" BorderBrush="#3A8DFF"
                            Click="Clone_Click"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══ EDITOR DIREITA ═══ -->
        <Grid Grid.Column="1">
            <TabControl Background="#121318" BorderBrush="#2B2E36" Foreground="White">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border Name="Border" BorderBrush="#2B2E36" BorderThickness="1,1,1,0" CornerRadius="4,4,0,0" Margin="2,0">
                                        <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="12,2"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#1A1C22"/>
                                            <Setter Property="Foreground" Value="Red"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="False">
                                            <Setter TargetName="Border" Property="Background" Value="#23262E"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- ── ABA GERAL (DROP) ── -->
                <TabItem Header="Drop">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="15">
                            
                            <!-- Propriedades Globais -->
                            <Border Background="#1A1C22" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="34"/>
                                        <RowDefinition Height="34"/>
                                        <RowDefinition Height="34"/>
                                        <RowDefinition Height="34"/>
                                    </Grid.RowDefinitions>

                                    <!-- Row 0 -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="ID" Foreground="AliceBlue" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBox x:Name="IdBox" Grid.Row="0" Grid.Column="1" IsReadOnly="True" Background="#23262E" Foreground="#888" BorderBrush="#333" Height="26" Margin="2" VerticalContentAlignment="Center" Padding="5,0"/>

                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Nome" Foreground="AliceBlue" VerticalAlignment="Center" FontSize="11" Margin="10,0,0,0" FontWeight="SemiBold"/>
                                    <TextBox x:Name="NameBox" Grid.Row="0" Grid.Column="3" Background="#23262E" Foreground="White" BorderBrush="#333" Height="26" Margin="2" VerticalContentAlignment="Center" Padding="5,0"/>

                                    <TextBlock Grid.Row="0" Grid.Column="4" Text="Nível" Foreground="AliceBlue" VerticalAlignment="Center" FontSize="11" Margin="10,0,0,0" FontWeight="SemiBold"/>
                                    <TextBox x:Name="LevelBox" Grid.Row="0" Grid.Column="5" Background="#23262E" Foreground="White" BorderBrush="#333" Height="26" Margin="2" VerticalContentAlignment="Center" Padding="5,0"/>

                                    <!-- Row 1 -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Tx Ouro (%)" Foreground="AliceBlue" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBox x:Name="DropGoldRateBox" Grid.Row="1" Grid.Column="1" Background="#23262E" Foreground="White" BorderBrush="#333" Height="26" Margin="2" VerticalContentAlignment="Center" Padding="5,0"/>

                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Ouro Médio" Foreground="AliceBlue" VerticalAlignment="Center" FontSize="11" Margin="10,0,0,0" FontWeight="SemiBold"/>
                                    <TextBox x:Name="AvgGoldBox" Grid.Row="1" Grid.Column="3" Background="#23262E" Foreground="White" BorderBrush="#333" Height="26" Margin="2" VerticalContentAlignment="Center" Padding="5,0"/>

                                    <TextBlock Grid.Row="1" Grid.Column="4" Text="Ouro Aleat" Foreground="AliceBlue" VerticalAlignment="Center" FontSize="11" Margin="10,0,0,0" FontWeight="SemiBold"/>
                                    <TextBox x:Name="RandGoldBox" Grid.Row="1" Grid.Column="5" Background="#23262E" Foreground="White" BorderBrush="#333" Height="26" Margin="2" VerticalContentAlignment="Center" Padding="5,0"/>

                                    <!-- Row 2 -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Vezes Aleat" Foreground="AliceBlue" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBox x:Name="RandTimesBox" Grid.Row="2" Grid.Column="1" Background="#23262E" Foreground="White" BorderBrush="#333" Height="26" Margin="2" VerticalContentAlignment="Center" Padding="5,0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Tx Não Drop" Foreground="AliceBlue" VerticalAlignment="Center" FontSize="11" Margin="10,0,0,0" FontWeight="SemiBold"/>
                                    <TextBox x:Name="NotDropRateBox" Grid.Row="2" Grid.Column="3" Background="#23262E" Foreground="White" BorderBrush="#333" Height="26" Margin="2" VerticalContentAlignment="Center" Padding="5,0"/>

                                    <!-- Row 3: Cores -->
                                    <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="6" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Taxas Cor:" Foreground="#8ED0FF" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="V:" Foreground="#00FF00" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,2,0"/>
                                        <TextBox x:Name="GreenRateBox" Width="45" Height="22" Background="#23262E" Foreground="White" BorderBrush="#333" FontSize="10" VerticalContentAlignment="Center" Padding="3,0"/>
                                        <TextBlock Text="A:" Foreground="#5CACFF" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,2,0"/>
                                        <TextBox x:Name="BlueRateBox" Width="45" Height="22" Background="#23262E" Foreground="White" BorderBrush="#333" FontSize="10" VerticalContentAlignment="Center" Padding="3,0"/>
                                        <TextBlock Text="L:" Foreground="#FFA500" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,2,0"/>
                                        <TextBox x:Name="OrangeRateBox" Width="45" Height="22" Background="#23262E" Foreground="White" BorderBrush="#333" FontSize="10" VerticalContentAlignment="Center" Padding="3,0"/>
                                        <TextBlock Text="Am:" Foreground="#FFFF00" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,2,0"/>
                                        <TextBox x:Name="YellowRateBox" Width="45" Height="22" Background="#23262E" Foreground="White" BorderBrush="#333" FontSize="10" VerticalContentAlignment="Center" Padding="3,0"/>
                                        <TextBlock Text="R:" Foreground="#D080FF" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,2,0"/>
                                        <TextBox x:Name="PurpleRateBox" Width="45" Height="22" Background="#23262E" Foreground="White" BorderBrush="#333" FontSize="10" VerticalContentAlignment="Center" Padding="3,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Height="1" Background="#2B2E36" Margin="0,5,0,15"/>

                            <!-- Slots de Drop (Paginados) -->
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="Itens de Drop" FontSize="16" FontWeight="SemiBold" Foreground="#8ED0FF" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="PageText" Text="(Página 1/5)" FontSize="13" Foreground="#B8C2D0" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    <Button Content="" FontFamily="Segoe MDL2 Assets" Width="34" Height="30" Margin="20,0,5,0" Click="PrevPage_Click" Background="#23262E" Foreground="White" BorderBrush="#333"/>
                                    <Button Content="" FontFamily="Segoe MDL2 Assets" Width="34" Height="30" Click="NextPage_Click" Background="#23262E" Foreground="White" BorderBrush="#333"/>
                                </StackPanel>

                                <ItemsControl x:Name="DropSlotsControl" Grid.Row="1">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="2"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1A1C22" BorderBrush="#333" BorderThickness="1" CornerRadius="8" Padding="10" Margin="4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="54"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <Border Width="48" Height="48" Background="#15171C" CornerRadius="4" BorderBrush="#444" BorderThickness="1" VerticalAlignment="Top">
                                                        <Image Source="{Binding Icon}" Stretch="Uniform"/>
                                                    </Border>
                                                    
                                                    <Grid Grid.Column="1" Margin="10,0,0,0">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        
                                                        <TextBlock Text="{Binding Index, StringFormat='Slot \{0\}'}" Foreground="#8ED0FF" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                        
                                                        <Grid Grid.Row="1">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="75"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="40"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            
                                                            <TextBlock Text="ID" Foreground="AliceBlue" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0" FontWeight="SemiBold"/>
                                                            <TextBox Grid.Column="1" Text="{Binding ItemId, UpdateSourceTrigger=PropertyChanged}" Height="22" FontSize="10" Background="#23262E" Foreground="White" BorderBrush="#333" VerticalContentAlignment="Center" Padding="3,0"/>
                                                            
                                                            <TextBlock Grid.Column="2" Text="Qtd" Foreground="AliceBlue" FontSize="10" VerticalAlignment="Center" Margin="8,0,4,0" FontWeight="SemiBold"/>
                                                            <TextBox Grid.Column="3" Text="{Binding Stack, UpdateSourceTrigger=PropertyChanged}" Height="22" FontSize="10" Background="#23262E" Foreground="White" BorderBrush="#333" VerticalContentAlignment="Center" Padding="3,0"/>
                                                            
                                                            <TextBlock Grid.Column="4" Text="Tx" Foreground="AliceBlue" FontSize="10" VerticalAlignment="Center" Margin="8,0,4,0" FontWeight="SemiBold"/>
                                                            <TextBox Grid.Column="5" Text="{Binding Rate, UpdateSourceTrigger=PropertyChanged}" Height="22" FontSize="10" Background="#23262E" Foreground="White" BorderBrush="#333" VerticalContentAlignment="Center" Padding="3,0"/>
                                                        </Grid>
                                                        
                                                        <TextBlock Grid.Row="2" Text="{Binding ItemName}" Foreground="White" FontSize="10" FontWeight="SemiBold" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ── ABA PLUS ── -->
                <TabItem Header="Plus">
                    <StackPanel Margin="20">
                        <TextBlock Text="Configurações Especiais" FontSize="18" FontWeight="SemiBold" Foreground="#8ED0FF" Margin="0,0,0,20"/>
                        
                        <Grid Margin="0,0,0,30">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Marquee String" Foreground="AliceBlue" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            <TextBox x:Name="MarqueeBox" Grid.Column="1" Background="#23262E" Foreground="White" BorderBrush="#333" Height="34" Padding="10,0" VerticalContentAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="Itens PB (V5+)" FontSize="16" FontWeight="SemiBold" Foreground="#FFD57A" Margin="0,0,0,15"/>
                        
                        <ItemsControl x:Name="PbSlotsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1A1C22" BorderBrush="#333" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="54"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <Border Width="48" Height="48" Background="#15171C" CornerRadius="6" BorderBrush="Gold" BorderThickness="2" VerticalAlignment="Top">
                                                <Image Source="{Binding Icon}" Stretch="Uniform"/>
                                            </Border>
                                            
                                            <Grid Grid.Column="1" Margin="15,0,0,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                
                                                <TextBlock Text="{Binding Index, StringFormat='PB Slot \{0\}'}" Foreground="#FFD57A" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                
                                                <Grid Grid.Row="1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <TextBlock Text="ID" Foreground="AliceBlue" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                                                    <TextBox Grid.Column="1" Text="{Binding ItemId, UpdateSourceTrigger=PropertyChanged}" Height="26" Background="#23262E" Foreground="White" BorderBrush="#333" VerticalContentAlignment="Center" Padding="5,0"/>
                                                    
                                                    <TextBlock Grid.Column="2" Text="Qtd" Foreground="AliceBlue" FontSize="11" VerticalAlignment="Center" Margin="15,0,5,0" FontWeight="SemiBold"/>
                                                    <TextBox Grid.Column="3" Text="{Binding Stack, UpdateSourceTrigger=PropertyChanged}" Height="26" Background="#23262E" Foreground="White" BorderBrush="#333" VerticalContentAlignment="Center" Padding="5,0"/>
                                                    
                                                    <TextBlock Grid.Column="4" Text="Taxa" Foreground="AliceBlue" FontSize="11" VerticalAlignment="Center" Margin="15,0,5,0" FontWeight="SemiBold"/>
                                                    <TextBox Grid.Column="5" Text="{Binding Rate, UpdateSourceTrigger=PropertyChanged}" Height="26" Background="#23262E" Foreground="White" BorderBrush="#333" VerticalContentAlignment="Center" Padding="5,0"/>
                                                </Grid>
                                                
                                                <TextBlock Grid.Row="2" Text="{Binding ItemName}" Foreground="White" FontSize="11" FontWeight="Bold" Margin="0,6,0,0"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</UserControl>
