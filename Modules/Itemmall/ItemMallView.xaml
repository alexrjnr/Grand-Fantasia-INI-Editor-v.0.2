<UserControl x:Class="GrandFantasiaINIEditor.Modules.ItemMall.ItemMallView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#0F0F12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LISTA -->
        <Border Background="#1A1C22" Padding="12" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="42"/>
                </Grid.RowDefinitions>

                <TextBlock Text="ItemMall Database"
                           FontSize="22"
                           Margin="0,0,0,10"
                           FontWeight="SemiBold">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="#4FD1FF" Offset="0.0" />
                            <GradientStop Color="#3A8DFF" Offset="0.6" />
                            <GradientStop Color="#2B58CC" Offset="1.0" />
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>

                <TextBox
                    x:Name="SearchBox"
                    Grid.Row="1"
                    Height="32"
                    Margin="0,0,0,10"
                    Background="#23262E"
                    Foreground="White"
                    BorderBrush="#333"
                    Padding="8,6"
                    TextChanged="SearchBox_TextChanged"/>

                <ListBox
                    x:Name="ItemList"
                    Grid.Row="2"
                    Background="#14161B"
                    Foreground="White"
                    BorderBrush="#2B2E36"
                    SelectionChanged="ItemList_SelectionChanged"/>

                <Grid Grid.Row="3" Margin="0,10,0,-10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="Resync S/C Item"
                            FontSize="9"
                            Height="30"
                            Margin="0,0,8,0"
                            Background="#A020F0"
                            Foreground="White"
                            BorderBrush="#A020F0"
                            Click="Reload_Click"/>

                    <Button Grid.Column="1"
                            Content="Salvar"
                            FontSize="9"
                            Height="30"
                            Margin="4,0,4,0"
                            Background="#2E8B57"
                            Foreground="White"
                            BorderBrush="#2E8B57"
                            Click="Save_Click"/>

                    <Button Grid.Column="2"
                            Content="Clonar"
                            FontSize="9"
                            Height="30"
                            Margin="8,0,0,0"
                            Background="#3A8DFF"
                            Foreground="White"
                            BorderBrush="#3A8DFF"
                            Click="Clone_Click"/>
                </Grid>
            </Grid>
        </Border>

        <!-- EDITOR -->
        <Grid Grid.Column="1">
            <TabControl Background="#121318" BorderBrush="#2B2E36" Foreground="White">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border Name="Border" BorderBrush="#2B2E36" BorderThickness="1,1,1,0" CornerRadius="4,4,0,0" Margin="2,0">
                                        <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="12,2"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#1A1C22"/>
                                            <Setter Property="Foreground" Value="Red"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="False">
                                            <Setter TargetName="Border" Property="Background" Value="#23262E"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- GERAL -->
                <TabItem Header="Geral">
                    
                        <Grid Margin="20">
                            <Grid.ColumnDefinitions>
