Grid.Row="2"
Grid.Column="2"
Width="107"
HorizontalAlignment="Right"
Margin="0,5,236,12"
Background="#23262E"
Foreground="Black"
BorderBrush="#333"
DisplayMemberPath="Label"
SelectedValuePath="Value" Grid.ColumnSpan="2">
