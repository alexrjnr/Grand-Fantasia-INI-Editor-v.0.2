<UserControl x:Class="GrandFantasiaINIEditor.Modules.Collection.CollectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:GrandFantasiaINIEditor.Modules.Collection">

    <Grid Background="#0F0F12">
        <Grid.Resources>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </Grid.Resources>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar: Categories Tree -->
        <Border Background="#1A1C22" Padding="10" Margin="0,0,5,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Categories" FontSize="20" Foreground="AliceBlue" FontWeight="Bold" Margin="0,0,0,10"/>

                <TreeView x:Name="CategoryTree" Grid.Row="1" Background="Transparent" BorderThickness="0" 
                          SelectedItemChanged="CategoryTree_SelectedItemChanged"
                          PreviewMouseRightButtonDown="CategoryTree_PreviewMouseRightButtonDown">
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type local:CollectionCategory}" ItemsSource="{Binding SubCategories}">
                            <TextBlock Text="{Binding Name}" Foreground="AliceBlue" Margin="2" Tag="{Binding}">
                                <TextBlock.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Selecionar Game Items (Top)" Click="SelectCategoryTop_Click" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Selecionar Item Mall Items (Bottom)" Click="SelectCategoryBottom_Click" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <Separator/>
                                        <MenuItem Header="Selecionar TUDO nesta Categoria" Click="SelectCategory_Click" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="DESMARCAR TUDO nesta Categoria" Click="UnselectCategory_Click" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    </ContextMenu>
                                </TextBlock.ContextMenu>
                            </TextBlock>
                        </HierarchicalDataTemplate>
                        
                        <DataTemplate DataType="{x:Type local:CollectionSubCategory}">
                            <TextBlock Text="{Binding Name}" Foreground="#AAA" Margin="2" Tag="{Binding}">
                                <TextBlock.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Selecionar Game Items (Top)" Click="SelectSubCategoryTop_Click" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Selecionar Item Mall Items (Bottom)" Click="SelectSubCategoryBottom_Click" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <Separator/>
                                        <MenuItem Header="Selecionar TUDO nesta Subcategoria" Click="SelectSubCategory_Click" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="DESMARCAR TUDO nesta Subcategoria" Click="UnselectSubCategory_Click" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    </ContextMenu>
                                </TextBlock.ContextMenu>
                            </TextBlock>
                        </DataTemplate>
                        
                        <!-- TreeView Styling -->
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Style.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3A8DFF"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#3A8DFF"/>
                            </Style.Resources>
                        </Style>
                    </TreeView.Resources>
                </TreeView>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Top Grid: Game Items -->
            <Border Background="#121318" Margin="5" BorderBrush="#2B2E36" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="#1A1C22" Padding="10,5" CornerRadius="4,4,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Game Items" Foreground="Gold" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TopScoreLabel" Text="Collection Score: 0 point(s)" Foreground="White" Margin="20,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ListBox x:Name="TopItemsList" Grid.Row="1" Background="Transparent" BorderThickness="0" Padding="10" 
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionMode="Extended"
                             MouseDoubleClick="ItemsList_MouseDoubleClick"
                             SelectionChanged="ItemsList_SelectionChanged">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="10" VerticalAlignment="Top"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2">
                                    <Border BorderBrush="Gold" BorderThickness="1" Background="#1A1C22" Cursor="Hand">
                                        <Border.ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Id, StringFormat='ID: {0}'}" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding ItemNameFromTItem}"/>
                                            </StackPanel>
                                        </Border.ToolTip>
                                        <Image Source="{Binding Icon}" Stretch="Uniform" Width="40" Height="40"/>
                                    </Border>
                                    <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="2">
                                        <CheckBox.Style>
                                            <Style TargetType="CheckBox">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="CheckBox">
                                                            <Border x:Name="border" Background="#80000000" BorderBrush="White" BorderThickness="1" Width="14" Height="14" CornerRadius="2">
                                                                <Path x:Name="checkMark" Data="M 0,2 L 3,5 L 8,0" Stroke="Gold" StrokeThickness="2" Visibility="Collapsed" Margin="1"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                                                    <Setter TargetName="border" Property="Background" Value="#A0000000"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </CheckBox.Style>
                                    </CheckBox>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Bottom Grid: Item Mall Items -->
            <Border Grid.Row="1" Background="#121318" Margin="5" BorderBrush="#2B2E36" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="#1A1C22" Padding="10,5" CornerRadius="4,4,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Item Mall Items" Foreground="Cyan" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="BottomScoreLabel" Text="Collection Score: 0 point(s)" Foreground="White" Margin="20,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ListBox x:Name="BottomItemsList" Grid.Row="1" Background="Transparent" BorderThickness="0" Padding="10" 
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionMode="Extended"
                             MouseDoubleClick="ItemsList_MouseDoubleClick"
                             SelectionChanged="ItemsList_SelectionChanged">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="10"  VerticalAlignment="Top"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2">
                                    <Border BorderBrush="Gold" BorderThickness="1" Background="#1A1C22" Cursor="Hand">
                                        <Border.ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Id, StringFormat='ID: {0}'}" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding ItemNameFromTItem}"/>
                                            </StackPanel>
                                        </Border.ToolTip>
                                        <Image Source="{Binding Icon}" Stretch="Uniform" Width="40" Height="40"/>
                                    </Border>
                                    <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="2">
                                        <CheckBox.Style>
                                            <Style TargetType="CheckBox">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="CheckBox">
                                                            <Border x:Name="border" Background="#80000000" BorderBrush="White" BorderThickness="1" Width="14" Height="14" CornerRadius="2">
                                                                <Path x:Name="checkMark" Data="M 0,2 L 3,5 L 8,0" Stroke="Gold" StrokeThickness="2" Visibility="Collapsed" Margin="1"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                                                    <Setter TargetName="border" Property="Background" Value="#A0000000"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </CheckBox.Style>
                                    </CheckBox>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Add/Edit Panel -->
            <Border Grid.Row="2" Background="#1A1C22" Margin="5" Padding="10" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Width="64" Height="64" Background="#23262E" BorderBrush="Gold" BorderThickness="1" Margin="0,0,10,0">
                        <Image x:Name="SelectedIcon" Stretch="Uniform"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="SelectedItemName" Text="Select an item" Foreground="AliceBlue" FontWeight="Bold"/>
                            <TextBlock x:Name="SelectedItemDesc" Text="-" Foreground="#AAA" FontSize="10" TextWrapping="Wrap" MaxWidth="300"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Content="Add New Item" Padding="15,5" Background="#2E8B57" Foreground="White" BorderThickness="0" Click="AddButton_Click"/>
                        <Button Content="Batch Add" Padding="15,5" Background="#8E44AD" Foreground="White" BorderThickness="0" Margin="10,0,0,0" Click="BatchAddButton_Click"/>
                        <Button Content="Remove Selected" Padding="15,5" Background="#C0392B" Foreground="White" BorderThickness="0" Margin="10,0,0,0" Click="RemoveSelected_Click"/>
                        <Button Content="Save All Changes" Padding="15,5" Background="#3A8DFF" Foreground="White" BorderThickness="0" Margin="10,0,0,0" Click="SaveAll_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock x:Name="TotalItemsLabel" Text="Total Items: 0" Foreground="White"/>
                        <TextBlock x:Name="TotalScoreLabel" Text="Total Score: 0" Foreground="Gold"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Loading Overlay -->
        <Grid Grid.ColumnSpan="2" Background="#80000000" Visibility="{Binding IsLoading, RelativeSource={RelativeSource AncestorType=local:CollectionView}, Converter={StaticResource BoolToVis}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="10" Foreground="#3A8DFF" Background="#1A1C22" BorderThickness="0"/>
                <TextBlock Text="Loading Collection Data..." Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0" FontSize="16"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
