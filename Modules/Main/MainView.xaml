<UserControl x:Class="GrandFantasiaINIEditor.Modules.Main.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:geral="clr-namespace:GrandFantasiaINIEditor.Modules.Geral"
             xmlns:item="clr-namespace:GrandFantasiaINIEditor.Modules.Item"
             xmlns:itemmall="clr-namespace:GrandFantasiaINIEditor.Modules.ItemMall"
             xmlns:dropitem="clr-namespace:GrandFantasiaINIEditor.Modules.DropItem"
             xmlns:enchant="clr-namespace:GrandFantasiaINIEditor.Modules.Enchant"
             xmlns:collection="clr-namespace:GrandFantasiaINIEditor.Modules.Collection"
             xmlns:loc="clr-namespace:GrandFantasiaINIEditor.Core">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#FF1A1A1D">
            <StackPanel>

                <TextBlock Text="{loc:Loc Main.Title}"
                           FontSize="22"
                           Margin="20,30,20,30"
                           TextAlignment="Center"
                           FontFamily="Segoe UI Semibold">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#FFE5A0" Offset="0.0"/>
                            <GradientStop Color="#FFD700" Offset="0.5"/>
                            <GradientStop Color="#B8860B" Offset="1.0"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.5"/>
                    </TextBlock.Effect>
                </TextBlock>

                <Button Content="{loc:Loc Main.Tabs.Geral}"
                        Click="Geral_Click"
                        Height="40"
                        Margin="15,5"
                        Foreground="White"
                        BorderBrush="#8B0000"
                        FontFamily="Segoe UI Semibold">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#E53935" Offset="0.0"/>
                            <GradientStop Color="#B71C1C" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

                <Button Content="{loc:Loc Main.Tabs.Items}"
                        Click="Item_Click"
                        Height="40"
                        Margin="15,5"
                        Foreground="#1A1A1D"
                        BorderBrush="#CCCCCC"
                        FontFamily="Segoe UI Semibold">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#FFFFFF" Offset="0.0"/>
                            <GradientStop Color="#A9A9A9" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

                <Button Content="{loc:Loc Main.Tabs.ItemMall}"
        Click="ItemMall_Click"
        Height="40"
        Margin="15,5"
        Foreground="#1A1A1D"
        BorderBrush="#CCCCCC"
        FontFamily="Segoe UI Semibold">
                    <Button.Background>
                        
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#FFFFFF" Offset="0.0"/>
                            <GradientStop Color="#A9A9A9" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

                <Button Content="{loc:Loc Main.Tabs.Mission}"
        Click="Mission_Click"
        Height="40"
        Margin="15,5"
        Foreground="#1A1A1D"
        BorderBrush="#CCCCCC"
        FontFamily="Segoe UI Semibold">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#FFFFFF" Offset="0.0"/>
                            <GradientStop Color="#A9A9A9" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>


                <Button Content="{loc:Loc Main.Tabs.Store}"
Click="Store_Click"
Height="40"
Margin="15,5"
Foreground="#1A1A1D"
BorderBrush="#CCCCCC"
FontFamily="Segoe UI Semibold">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#FFFFFF" Offset="0.0"/>
                            <GradientStop Color="#A9A9A9" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

                <Button Content="{loc:Loc Main.Tabs.ElfCombine}"
                        Click="ElfCombine_Click"
                        Height="40"
                        Margin="15,5"
                        Foreground="#1A1A1D"
                        BorderBrush="#CCCCCC"
                        FontFamily="Segoe UI Semibold">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#A0F0C0" Offset="0.0"/>
                            <GradientStop Color="#3ABFFF" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

                <Button Content="{loc:Loc Main.Tabs.DropItem}"
                        Click="DropItem_Click"
                        Height="40"
                        Margin="15,5"
                        Foreground="#1A1A1D"
                        BorderBrush="#CCCCCC"
                        FontFamily="Segoe UI Semibold">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#F0A0C0" Offset="0.0"/>
                            <GradientStop Color="#FFAB3A" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

                <Button Content="{loc:Loc Main.Tabs.Enchant}"
                        Click="Enchant_Click"
                        Height="40"
                        Margin="15,5"
                        Foreground="#1A1A1D"
                        BorderBrush="#CCCCCC"
                        FontFamily="Segoe UI Semibold">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#FFD700" Offset="0.0"/>
                            <GradientStop Color="#FF8C00" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

                <Button Content="{loc:Loc Main.Tabs.Collection}"
                        Click="Collection_Click"
                        Height="40"
                        Margin="15,5"
                        Foreground="White"
                        BorderBrush="#DAA520"
                        FontFamily="Segoe UI Semibold">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#8A2BE2" Offset="0.0"/>
                            <GradientStop Color="#4B0082" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

                <Button Content="{loc:Loc Main.Tabs.Npc}"
                        Click="Npc_Click"
                        Height="40"
                        Margin="15,5"
                        Foreground="White"
                        BorderBrush="#FF5722"
                        FontFamily="Segoe UI Semibold">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#FF8A65" Offset="0.0"/>
                            <GradientStop Color="#D84315" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

                <Button Content="{loc:Loc Main.Tabs.Monster}"
                        Click="Monster_Click"
                        Height="40"
                        Margin="15,5"
                        Foreground="White"
                        BorderBrush="#607D8B"
                        FontFamily="Segoe UI Semibold">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#90A4AE" Offset="0.0"/>
                            <GradientStop Color="#455A64" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

                <Button Content="{loc:Loc Main.Tabs.Scene}"
                        Click="Scene_Click"
                        Height="40"
                        Margin="15,5"
                        Foreground="White"
                        BorderBrush="#3F51B5"
                        FontFamily="Segoe UI Semibold">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#5C6BC0" Offset="0.0"/>
                            <GradientStop Color="#3949AB" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Background="#F5F5F5">
            <ContentControl x:Name="MainContent"/>
        </Grid>

    </Grid>
</UserControl>
