<UserControl x:Class="GrandFantasiaINIEditor.Modules.Item.ItemView"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:loc="clr-namespace:GrandFantasiaINIEditor.Core">

    <Grid Background="#0F0F12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LISTA -->
        <Border Background="#1A1C22" Padding="12" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="42"/>
                </Grid.RowDefinitions>

                <TextBlock Text="{loc:Loc Item.Labels.ItemDatabase}"
                           FontSize="22"
                           Margin="0,0,0,10"
                           FontWeight="SemiBold">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="#4FD1FF" Offset="0.0" />
                            <GradientStop Color="#3A8DFF" Offset="0.6" />
                            <GradientStop Color="#2B58CC" Offset="1.0" />
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>

                <TextBox
                    x:Name="SearchBox"
                    Grid.Row="1"
                    Height="32"
                    Margin="0,0,0,10"
                    Background="#23262E"
                    Foreground="White"
                    BorderBrush="#333"
                    Padding="8,6"
                    TextChanged="SearchBox_TextChanged"/>

                <ListBox
                    x:Name="ItemList"
                    Grid.Row="2"
                    Background="#14161B"
                    Foreground="White"
                    BorderBrush="#2B2E36"
                    SelectionChanged="ItemList_SelectionChanged"/>

                <Grid Grid.Row="3" Margin="0,10,0,-10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="{loc:Loc Item.Labels.Resync}"
                            FontSize="9"
                            Height="30"
                            Margin="0,0,8,0"
                            Background="#A020F0"
                            Foreground="White"
                            BorderBrush="#A020F0"
                            Click="Reload_Click"/>

                    <Button Grid.Column="1"
                            Content="{loc:Loc Common.Save}"
                            FontSize="9"
                            Height="30"
                            Margin="4,0,4,0"
                            Background="#2E8B57"
                            Foreground="White"
                            BorderBrush="#2E8B57"
                            Click="Save_Click"/>

                    <Button Grid.Column="2"
                            Content="{loc:Loc Common.Clone}"
                            FontSize="9"
                            Height="30"
                            Margin="8,0,0,0"
                            Background="#3A8DFF"
                            Foreground="White"
                            BorderBrush="#3A8DFF"
                            Click="Clone_Click"/>
                </Grid>
            </Grid>
        </Border>

        <!-- EDITOR -->
        <Grid Grid.Column="1">
            <TabControl Background="#121318" BorderBrush="#2B2E36" Foreground="White">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border Name="Border" BorderBrush="#2B2E36" BorderThickness="1,1,1,0" CornerRadius="4,4,0,0" Margin="2,0">
                                        <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="12,2"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#1A1C22"/>
                                            <Setter Property="Foreground" Value="Red"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="False">
                                            <Setter TargetName="Border" Property="Background" Value="#23262E"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- GERAL -->
                <TabItem Header="{loc:Loc Main.Tabs.Geral}">

                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                    Grid.RowSpan="2"
                                    Width="72"
                                    Height="72"
                                    CornerRadius="10"
                                    BorderBrush="Gold"
                                    BorderThickness="2"
                                    Background="#23262E"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top">
                            <Image x:Name="ItemIcon"
                                       Width="56"
                                       Height="56"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="{loc:Loc Common.Name}"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top"
                                       Grid.ColumnSpan="2"
                                       Margin="78,2,42,0"/>
                        <TextBox x:Name="NameBox"
                                     Margin="78,20,42,30"
                                     Height="30"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Grid.ColumnSpan="2"
                                     Grid.RowSpan="2"/>

                        <TextBlock Text="{loc:Loc Item.Labels.Icon}"
                                       Grid.Row="2"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Center"/>
                        <TextBox x:Name="IconBox"
                                     Grid.Row="2"
                                     Height="30"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Margin="52,5,244,5" Grid.ColumnSpan="2"/>

                        <TextBlock Text="{loc:Loc Item.Labels.Model}"
                                       Grid.Row="3"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Center" Margin="-3,0,3,0"/>
                        <TextBox x:Name="ModelIdBox"
                                     Grid.Row="3"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Margin="52,5,244,10" Grid.ColumnSpan="2"/>

                        <TextBlock Text="{loc:Loc Item.Labels.Box}"
                                       Grid.Row="4"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top" Margin="0,7,0,0"/>
                        <TextBox x:Name="ModelFileBox"
                                     Grid.Row="4"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Margin="52,5,244,10" Grid.ColumnSpan="2"/>

                        <TextBlock Text="{loc:Loc Item.Labels.ItemType}"
                                       Grid.Row="2"
                                       Grid.Column="1"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top"
                                       Margin="40,7,100,0"/>
                        <ComboBox x:Name="ItemTypeCombo"
                                      Grid.Row="2"
                                      Grid.Column="1"
                                      Background="#232620"
                                      Foreground="Black"
                                      BorderBrush="#333"
                                      Margin="116,4,27,10"/>

                        <TextBlock Text="{loc:Loc Item.Labels.Quality}"
                                       Grid.Row="3"
                                       Grid.Column="1"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top"
                                       Margin="40,8,100,0"/>
                        <ComboBox x:Name="QualityCombo"
                                      Grid.Row="3"
                                      Grid.Column="1"
                                      Background="#23262E"
                                      Foreground="Black"
                                      BorderBrush="#333"
                                      Margin="116,5,27,10"/>

                        <TextBlock Text="{loc:Loc Item.Labels.MinLevel}"
                                       Grid.Row="4"
                                       Grid.Column="1"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top"
                                       Margin="40,7,100,0"/>
                        <TextBox x:Name="LevelBox"
                                     Grid.Row="4"
                                     Grid.Column="1"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Margin="116,5,27,10"/>

                        <TextBlock Text="{loc:Loc Common.Description}"
                                       Grid.Column="2"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top"
                                       Margin="0,-1,0,0"/>
                        <TextBox x:Name="DescBox"
                                     Grid.Column="2"
                                     Grid.RowSpan="2"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Grid.ColumnSpan="2"
                                     Margin="0,20,10,6"/>

                        <TextBlock Text="{loc:Loc Item.Labels.EquipType}"
                                       Grid.Row="5"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top" Margin="64,8,76,0" Grid.Column="1"/>
                        <ComboBox x:Name="EquipTypeCombo"
                                      Grid.Row="5"
                                      Background="#23262E"
                                      Foreground="Black"
                                      BorderBrush="#333"
                                      Margin="147,5,85,10"
                                      Grid.ColumnSpan="2" Grid.Column="1"/>

                        <TextBlock Text="{loc:Loc Item.Labels.Target}"
                                       Grid.Row="5"
                                       Grid.Column="2"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top"
                                       Margin="50,10,210,0" Grid.ColumnSpan="2"/>
                        <ComboBox x:Name="TargetCombo"
                                      Grid.Row="5"
                                      Grid.Column="2"
                                      Background="#23262E"
                                      Foreground="Black"
                                      BorderBrush="#333"
                                      Margin="80,8,183,8"
                                      Grid.ColumnSpan="2"/>

                        <TextBlock Text="{loc:Loc Item.Labels.MaxStacks}"
                                       Grid.Row="6"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top" Grid.ColumnSpan="2" Margin="19,9,241,0"/>
                        <TextBox x:Name="MaxStackBox"
                                     Grid.Row="6"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Margin="115,5,191,10"
                                     Grid.ColumnSpan="2"/>

                        <TextBlock Text="{loc:Loc Item.Labels.MaxSlot}"
                                       Grid.Row="6"
                                       Grid.Column="1"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Center"
                                       Margin="180,0,79,0" Grid.ColumnSpan="2"/>
                        <TextBox x:Name="MaxSocketBox"
                                     Grid.Row="6"
                                     Grid.Column="2"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Margin="3,5,0,10" />

                        <TextBlock Text="{loc:Loc Item.Labels.SlotRate}"
                                       Grid.Row="7"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top" Grid.Column="1" Margin="180,5,80,0" Grid.ColumnSpan="2"/>
                        <TextBox x:Name="SocketRateBox"
                                     Grid.Row="7"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Margin="3,3,0,12" Grid.Column="2"/>

                        <TextBlock Text="{loc:Loc Item.Labels.Currency}"
                                       Grid.Row="4"
                                       Grid.Column="3"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top"
                                       Margin="87,7,125,0"/>
                        <ComboBox x:Name="ShopPriceTypeCombo"
                                      Grid.Row="4"
                                      Grid.Column="3"
                                      Background="#23262E"
                                      Foreground="Black"
                                      BorderBrush="#333"
                                      Margin="130,2,10,8"/>

                        <TextBlock Text="{loc:Loc Item.Labels.Price}"
                                       Grid.Row="5"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top" Grid.Column="3" Margin="95,9,45,0"/>
                        <TextBox x:Name="SysPriceBox"
                                     Grid.Row="5"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Margin="130,5,10,10" Grid.Column="3"/>

                        <TextBlock Text="{loc:Loc Item.Labels.MaxLevel}"
                                       Grid.Row="4"
                                       Grid.Column="1"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top"
                                       Margin="238,7,22,0" Grid.ColumnSpan="2"/>
                        <TextBox x:Name="RestrictMaxLevelBox"
                                     Grid.Row="4"
                                     Grid.Column="2"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Margin="41,2,222,13" Grid.ColumnSpan="2"/>

                        <TextBlock Text="{loc:Loc Item.Labels.Cooldown}"
                                       Grid.Row="9"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top" Margin="20,3,240,0" Grid.ColumnSpan="2"/>
                        <TextBox x:Name="CoolDownTimeBox"
                                     Grid.Row="9"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Margin="111,0,195,15"
                                     Grid.ColumnSpan="2" />

                        <TextBlock Text="{loc:Loc Item.Labels.CdGroup}"
                                       Grid.Row="10"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top"
                                       Margin="24,3,236,0" Grid.ColumnSpan="2"/>
                        <TextBox x:Name="CoolDownGroupBox"
                                     Grid.Row="10"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Margin="111,0,195,15"
                                     Grid.ColumnSpan="2"/>

                        <TextBlock Text="{loc:Loc Item.Labels.ItemGroup}"
                                       Grid.Row="11"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top" Grid.ColumnSpan="2" Margin="14,3,246,0"/>
                        <TextBox x:Name="ItemGroupBox"
                                     Grid.Row="11"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Margin="111,0,195,15" Grid.ColumnSpan="2" />

                        <TextBlock Text="{loc:Loc Item.Labels.Casting}"
                                       Grid.Row="10"
                                       Grid.Column="1"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top"
                                       Margin="140,3,0,0"/>
                        <TextBox x:Name="CastingTimeBox"
                                     Grid.Row="9"
                                     Grid.Column="1"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Margin="209,39,104,18" Grid.RowSpan="2" Grid.ColumnSpan="2"/>

                        <TextBlock Text="{loc:Loc Item.Labels.RebirthCount}"
                                       Grid.Row="10"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Center" Grid.Column="3" Margin="27,0,113,0"/>
                        <TextBox x:Name="RebirthCountBox"
                                     Grid.Row="10"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Margin="133,12,10,3" Grid.Column="3"/>

                        <TextBlock Text="{loc:Loc Item.Labels.RebirthMax}"
                                       Grid.Row="11"
                                       Grid.Column="3"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top"
                                       Margin="36,8,104,0"/>
                        <TextBox x:Name="RebirthMaxScoreBox"
                                     Grid.Row="11"
                                     Grid.Column="3"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Margin="133,5,10,12"/>

                        <TextBlock Text="{loc:Loc Item.Labels.Gender}"
           Grid.Row="2"
           Grid.Column="1"
           Grid.ColumnSpan="2"
           Foreground="AliceBlue"
           FontFamily="Segoe UI Semibold"
           VerticalAlignment="Top"
           Margin="250,7,10,0"/>

                        <ComboBox x:Name="RestrictGenderCombo"
          Grid.Row="2"
          Grid.Column="2"
          Width="107"
          HorizontalAlignment="Right"
          Margin="0,5,236,12"
          Background="#23262E"
          Foreground="Black"
          BorderBrush="#333"
          DisplayMemberPath="Label"
          SelectedValuePath="Value" Grid.ColumnSpan="2">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="Background" Value="White"/>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>

                        <TextBlock Text="{loc:Loc Item.Labels.RebirthScore}"
                                       Grid.Row="12"
                                       Grid.Column="3"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top"
                                       Margin="30,8,110,0"/>
                        <TextBox x:Name="RebirthScoreBox"
                                     Grid.Row="12"
                                     Grid.Column="3"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Margin="133,5,10,10"/>

                        <TextBlock Text="{loc:Loc Item.Labels.FameRequired}"
           Grid.Row="7"
           Foreground="AliceBlue"
           FontFamily="Segoe UI Semibold"
           VerticalAlignment="Top" Grid.Column="3" Margin="17,5,123,0"/>
                        <ComboBox x:Name="RestrictAlignCombo"
          Grid.Row="7"
          Grid.Column="3"
          Background="#23262E"
          Foreground="black"
          BorderBrush="#333"
          Margin="113,3,10,12"
          DisplayMemberPath="Label"
          SelectedValuePath="Value">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="Background" Value="White"/>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>

                        <TextBlock Text="{loc:Loc Item.Labels.Amount}"
           Grid.Row="8"
           Grid.Column="3"
           Foreground="AliceBlue"
           FontFamily="Segoe UI Semibold"
           VerticalAlignment="Top"
           Margin="45,7,95,0"/>
                        <TextBox x:Name="RestrictPrestigeBox"
         Grid.Row="8"
         Grid.Column="3"
         Background="#23262E"
         Foreground="White"
         BorderBrush="#333"
         Margin="113,7,10,9"/>

                        <TextBlock Text="{loc:Loc Item.Labels.BackpackSize}"
                                       Grid.Row="14"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top" Margin="0,2,0,0"/>
                        <TextBox x:Name="BackpackSizeBox"
                                     Grid.Row="13"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Margin="111,39,195,16"
                                     Grid.ColumnSpan="2" Grid.RowSpan="2"/>

                        <TextBlock Text="{loc:Loc Item.Labels.MaxDurability}"
                                       Grid.Row="7"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top" RenderTransformOrigin="0.517,-0.437" Margin="-1,7,1,0"/>
                        <TextBox x:Name="MaxDurabilityBox"
                                     Grid.Row="7"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Margin="116,5,191,10" Grid.ColumnSpan="2"/>

                        <TextBlock Text="{loc:Loc Item.Labels.EventPos}"
                                       Grid.Row="14"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Top" Grid.Column="1" Margin="106,1,34,0"/>
                        <TextBox x:Name="RestrictEventPosIdBox"
                                     Grid.Row="13"
                                     Background="#23262E"
                                     Foreground="White"
                                     BorderBrush="#333"
                                     Margin="184,39,2,16" Grid.Column="1" Grid.RowSpan="2"/>
                    </Grid>

                </TabItem>

                <!-- STATUS -->
                <TabItem Header="{loc:Loc Main.Tabs.Status}">

                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{loc:Loc Item.Labels.Hp}" Foreground="AliceBlue" FontFamily="Segoe UI Semibold" VerticalAlignment="Top" Margin="0,7,0,0"/>
                        <TextBox x:Name="HpBox" Background="#23262E" Foreground="White" BorderBrush="#333" Grid.ColumnSpan="2" Margin="22,5,118,10"/>

                        <TextBlock Text="{loc:Loc Item.Labels.Mp}" Foreground="AliceBlue" FontFamily="Segoe UI Semibold" VerticalAlignment="Top" Grid.Column="1" Grid.ColumnSpan="2" Margin="37,4,113,0"/>
                        <TextBox x:Name="MpBox" Background="#23262E" Foreground="White" BorderBrush="#333" Grid.ColumnSpan="2" Margin="62,3,78,10" Grid.Column="1"/>

                        <TextBlock Text="{loc:Loc Item.Labels.Str}" Foreground="AliceBlue" FontFamily="Segoe UI Semibold" VerticalAlignment="Top" Grid.Column="2" Margin="98,9,27,0"/>
                        <TextBox x:Name="StrBox" Grid.Column="2" Background="#23262E" Foreground="White" BorderBrush="#333" Grid.ColumnSpan="2" Margin="123,10,82,15"/>

                        <TextBlock Text="{loc:Loc Item.Labels.Vit}" Foreground="AliceBlue" FontFamily="Segoe UI Semibold" VerticalAlignment="Top" Grid.Column="2" Margin="98,29,27,0" Grid.RowSpan="2"/>
                        <TextBox x:Name="DexBox" Grid.Column="2" Background="#23262E" Foreground="White" BorderBrush="#333" Margin="123,30,82,35" Grid.ColumnSpan="2" Grid.RowSpan="2"/>

                        <TextBlock Text="{loc:Loc Item.Labels.Int}" Grid.Row="1" Foreground="AliceBlue" FontFamily="Segoe UI Semibold" VerticalAlignment="Top" Grid.Column="2" Margin="97,9,27,0"/>
                        <TextBox x:Name="IntBox" Grid.Column="2" Background="#23262E" Foreground="White" BorderBrush="#333" Margin="123,10,82,15" Grid.ColumnSpan="2" Grid.Row="1"/>

                        <TextBlock Text="{loc:Loc Item.Labels.AtkF}" Foreground="AliceBlue" FontFamily="Segoe UI Semibold" VerticalAlignment="Center" Grid.Row="1"/>
                        <TextBox x:Name="AtkBox" Background="#23262E" Foreground="White" BorderBrush="#333" Margin="37,12,43,10" Grid.Row="1"/>

                        <TextBlock Text="{loc:Loc Item.Labels.DefF}" Grid.Row="1" Foreground="AliceBlue" FontFamily="Segoe UI Semibold" VerticalAlignment="Top" Margin="119,12,31,0" Grid.ColumnSpan="2"/>
                        <TextBox x:Name="DefBox" Grid.Row="1" Background="#23262E" Foreground="White" BorderBrush="#333" Margin="25,12,52,10" Grid.Column="1"/>

                        <TextBlock Text="{loc:Loc Item.Labels.AtkM}" Grid.Row="1" Foreground="AliceBlue" FontFamily="Segoe UI Semibold" VerticalAlignment="Center" Grid.RowSpan="2"/>
                        <TextBox x:Name="MatkBox" Grid.Row="1" Background="#23262E" Foreground="White" BorderBrush="#333" Margin="37,32,43,31" Grid.RowSpan="2"/>

                        <TextBlock Text="{loc:Loc Item.Labels.DefM}" Grid.Row="1" Foreground="AliceBlue" FontFamily="Segoe UI Semibold" VerticalAlignment="Top" Margin="119,32,31,0" Grid.RowSpan="2" Grid.ColumnSpan="2"/>
                        <TextBox x:Name="MdefBox" Grid.Row="1" Grid.Column="1" Background="#23262E" Foreground="White" BorderBrush="#333" Margin="25,32,52,32" Grid.RowSpan="2"/>

