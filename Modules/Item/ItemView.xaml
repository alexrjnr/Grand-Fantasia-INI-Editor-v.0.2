                <!-- FLAGS -->
                <TabItem Header="{loc:Loc Main.Tabs.Flags}" HorizontalAlignment="Left" Width="59">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{loc:Loc Item.Labels.OpFlags}"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Center"/>

                            <TextBlock x:Name="opflags_value"
                                       Grid.Row="1"
                                       Grid.ColumnSpan="3"
                                       Foreground="#C8C8C8"
                                       FontFamily="Consolas"
                                       VerticalAlignment="Center"
                                       Text="0  |  0x0"/>

                            <Border Grid.Row="2"
                                    Grid.ColumnSpan="3"
                                    Background="#17191F"
                                    BorderBrush="#333"
                                    BorderThickness="1"
                                    Padding="10"
                                    CornerRadius="6">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="220">
                                    <UniformGrid x:Name="op_grid" Columns="4"/>
                                </ScrollViewer>
                            </Border>

                            <TextBlock Text="{loc:Loc Item.Labels.OpFlagsPlus}"
                                       Grid.Row="3"
                                       Foreground="AliceBlue"
                                       FontFamily="Segoe UI Semibold"
                                       VerticalAlignment="Center"/>

                            <TextBlock x:Name="opflagsplus_value"
                                       Grid.Row="4"
                                       Grid.ColumnSpan="3"
                                       Foreground="#C8C8C8"
                                       FontFamily="Consolas"
                                       VerticalAlignment="Center"
                                       Text="0  |  0x0"/>

                            <Border Grid.Row="5"
                                    Grid.ColumnSpan="3"
                                    Background="#17191F"
                                    BorderBrush="#333"
                                    BorderThickness="1"
                                    Padding="10"
                                    CornerRadius="6">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="220">
                                    <UniformGrid x:Name="opplus_grid" Columns="4"/>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Grid>
    </Grid>
</UserControl>