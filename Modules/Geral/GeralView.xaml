<UserControl x:Class="GrandFantasiaINIEditor.Modules.Geral.GeralView"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>

        <Grid.Background>
            <ImageBrush ImageSource="/Assets/images/background.png"
Stretch="UniformToFill"/>
        </Grid.Background>

        <Grid Background="#88000000">

            <StackPanel VerticalAlignment="Center"
HorizontalAlignment="Center"
Width="600">

                <TextBlock Text="Grand Fantasia INI Editor"
           FontSize="36"
           FontWeight="Bold">
    <TextBlock.Foreground>
        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
            <GradientStop Color="#FFB800" Offset="0.0" />
            <GradientStop Color="#FFF2A0" Offset="0.5" />
            <GradientStop Color="#D4A017" Offset="1.0" />
        </LinearGradientBrush>
    </TextBlock.Foreground>
</TextBlock>

                <TextBlock Text="Ferramenta de edição de arquivos INI do Grand Fantasia."
FontSize="16"
Foreground="White"
TextAlignment="Center"
Margin="0 0 0 20"/>

                <TextBlock Text="Author:"
           FontSize="18"
           HorizontalAlignment="Left" 
           Margin="10,0,0,0">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#FFD700" Offset="0.0"/>
                            <GradientStop Color="#B8860B" Offset="1.0"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>

                <TextBlock FontSize="18"
           HorizontalAlignment="Left"
           Margin="75,-23,0,10">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFF2A0" Offset="0.0"/>
                            <GradientStop Color="#FFD700" Offset="0.5"/>
                            <GradientStop Color="#DAA520" Offset="1.0"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
    <Run Language="pt-br" Text="Alex R. Jnr (Budda)"/>
                </TextBlock>



                <TextBlock  Text="Manual de uso Ini edit: Matenha os Inis C/S dentro do diretorio data/db e aponte a pasta raiz na pagina de loguin " 
Foreground="White"
HorizontalAlignment="Left"
Margin="10,60,0,30"
FontFamily="Segoe UI Semibold" Width="597" FontSize="11"/>


                <TextBlock Text="Version 0.1" 
Foreground="White" HorizontalAlignment="Right" Margin="0,0,10,0"                           />
            </StackPanel>

        </Grid>

    </Grid>

</UserControl>